---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import ContentPage from '@/components/ContentPage.astro';
import ArticleSchema from '@/components/seo/ArticleSchema.astro';
import BreadcrumbSchema from '@/components/seo/BreadcrumbSchema.astro';
import { estimateReadingTime } from '@/utils/estimateReadingTime';

export async function getStaticPaths() {
  const toSlug = (id: string) => id.replace(/\.(md|mdx)$/, '').toLowerCase();
  const allPosts = await getCollection('blog');

  return allPosts.map(p => {
    const slug = toSlug(p.id);
    const isSubArticle = slug.includes('/');
    const isSeriesHome = !isSubArticle && allPosts.some(a => toSlug(a.id).startsWith(slug + '/'));

    let seriesArticles = undefined;
    let parentSeries = undefined;
    let prevArticle = undefined;
    let nextArticle = undefined;

    if (isSeriesHome) {
      seriesArticles = allPosts
        .filter(a => toSlug(a.id).startsWith(slug + '/'))
        .sort((a, b) => (a.data.articleNumber ?? 0) - (b.data.articleNumber ?? 0));
    }

    if (isSubArticle) {
      const parentSlug = slug.split('/')[0];
      const siblings = allPosts
        .filter(a => toSlug(a.id).startsWith(parentSlug + '/'))
        .sort((a, b) => (a.data.articleNumber ?? 0) - (b.data.articleNumber ?? 0));
      parentSeries = allPosts.find(a => toSlug(a.id) === parentSlug);
      const idx = siblings.findIndex(a => a.id === p.id);
      prevArticle = idx > 0 ? siblings[idx - 1] : undefined;
      nextArticle = idx < siblings.length - 1 ? siblings[idx + 1] : undefined;
      seriesArticles = siblings;
    }

    return {
      params: { slug },
      props: { entry: p, seriesArticles, parentSeries, prevArticle, nextArticle },
    };
  });
}

const { entry, seriesArticles, parentSeries, prevArticle, nextArticle } = Astro.props;
const stats = estimateReadingTime(entry.body);
const { Content } = await entry.render();

// Build SEO props from frontmatter
const entrySlug = entry.id.replace(/\.(md|mdx)$/, '').toLowerCase();
const canonicalUrl = entry.data.canonical || `/blog/${entrySlug}/`;
const ogImage = entry.data.ogImage || '/social-prev.png';
---
<Layout
  title={entry.data.title + ' | Siddhant Shah'}
  description={entry.data.description}
  canonical={canonicalUrl}
  og={{
    title: entry.data.title,
    type: "article",
    description: entry.data.description,
    image: ogImage,
    alt: entry.data.title
  }}
>
  <link
    slot="head"
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/katex@0.15.2/dist/katex.min.css"
    integrity="sha384-MlJdn/WNKDGXveldHDdyRP1R4CTHr3FeuDNfhsLPYrq2t0UBkUdK2jyTnXPEK1NQ"
    crossorigin="anonymous"
  />
  <script slot="head" defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "e709a605fa1c4a3895e2987e5a9ca9c6"}'></script>
  {import.meta.env.PROD && <script slot="head" data-goatcounter="https://siddhants.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>}

  <ArticleSchema
    slot="head"
    title={entry.data.title}
    description={entry.data.description}
    publishedAt={entry.data.publishedAt}
    updatedAt={entry.data.updatedAt}
    slug={entrySlug}
    image={ogImage}
    tags={entry.data.tags}
  />
  <BreadcrumbSchema
    slot="head"
    items={parentSeries ? [
      { name: "Home", url: "/" },
      { name: "Blog", url: "/blog/" },
      { name: parentSeries.data.title, url: `/blog/${parentSeries.id.replace(/\.(md|mdx)$/, '')}/` },
      { name: entry.data.title }
    ] : [
      { name: "Home", url: "/" },
      { name: "Blog", url: "/blog/" },
      { name: entry.data.title }
    ]}
  />

  <ContentPage
    type="blog"
    entry={entry}
    Content={Content}
    readingTime={stats.minutes}
    seriesArticles={seriesArticles}
    parentSeries={parentSeries}
    prevArticle={prevArticle}
    nextArticle={nextArticle}
  />
</Layout>
