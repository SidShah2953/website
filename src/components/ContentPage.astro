---
import type { CollectionEntry } from "astro:content";
import { marked } from "marked";

export type ContentType = "blog" | "project" | "research";

type BlogEntry = CollectionEntry<"blog">;
type ProjectEntry = CollectionEntry<"projects">;
type ResearchEntry = CollectionEntry<"research">;

export interface Props {
  type: ContentType;
  entry: BlogEntry | ProjectEntry | ResearchEntry;
  Content: any;
  readingTime?: number;
  // Series support
  seriesArticles?: BlogEntry[];   // populated for series home pages
  parentSeries?: BlogEntry;       // populated for sub-articles
  prevArticle?: BlogEntry;        // populated for sub-articles
  nextArticle?: BlogEntry;        // populated for sub-articles
}

const { type, entry, Content, readingTime, seriesArticles, parentSeries, prevArticle, nextArticle } = Astro.props;

const isResearch = type === "research";

// Helper to format date
const formatDate = (date: Date, style: "long" | "short" = "long") => {
  if (style === "long") {
    return date.toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    });
  }
  return date.toDateString();
};

// Type guards
const isBlogEntry = (e: typeof entry): e is BlogEntry => type === "blog";
const isResearchEntry = (e: typeof entry): e is ResearchEntry => type === "research";

// Get thesis if present and render as markdown
const thesis = entry.data.thesis;
const thesisHtml = thesis ? await marked.parse(thesis) : null;
---

<main class="flex flex-col gap-8 w-full">
  <!-- Full-width Article Metadata Section -->
  <header class="glass-card p-8 md:p-12 w-full">
    <div class="flex flex-col gap-4">
      <h1 class="text-4xl md:text-5xl font-bold gradient-text leading-tight">{entry.data.title}</h1>

      {entry.data.description && (
        <p class="text-lg text-neutral-300 leading-relaxed">{entry.data.description}</p>
      )}

      <!-- Sub-article: series breadcrumb -->
      {isBlogEntry(entry) && parentSeries && (
        <div class="flex items-center gap-2 flex-wrap text-sm">
          <a href={`/blog/${parentSeries.slug}`} class="inline-flex items-center gap-1.5 text-finance-purple hover:text-white transition-colors font-medium">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/>
              <line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/>
            </svg>
            {parentSeries.data.title}
          </a>
          {entry.data.articleNumber != null && seriesArticles && seriesArticles.length > 0 && (
            <>
              <span class="text-neutral-600">·</span>
              <span class="text-neutral-400">Part {entry.data.articleNumber} of {seriesArticles.length}</span>
            </>
          )}
        </div>
      )}

      <!-- Blog-specific: "Written by" line -->
      {isBlogEntry(entry) && (
        <p class="text-sm text-neutral-400">
          Written by Siddhant Shah on <time datetime={entry.data.publishedAt.toISOString()}>{formatDate(entry.data.publishedAt)}</time>
        </p>
      )}

      <!-- Project/Research: Date only -->
      {!isBlogEntry(entry) && (
        <div class="flex items-center gap-2 text-sm text-neutral-400">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <time datetime={entry.data.publishedAt.toISOString()}>
            {formatDate(entry.data.publishedAt, type === "research" ? "short" : "long")}
          </time>
        </div>
      )}

      <!-- Research-specific: Authors and Publication -->
      {isResearchEntry(entry) && (
        <div class="flex flex-col gap-2">
          <p class="text-neutral-400">
            <span class="text-neutral-500 font-semibold">Authors:</span> {entry.data.authors.join(", ")}
          </p>
          {entry.data.publication && (
            <p class="text-finance-cyan font-medium">{entry.data.publication}</p>
          )}
        </div>
      )}

      <!-- Blog: Reading time and clickable tags -->
      {isBlogEntry(entry) && (
        <div class="flex flex-wrap gap-4 text-sm text-neutral-400 items-center">
          {readingTime && (
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {readingTime} min read
            </span>
          )}
          {entry.data.tags && entry.data.tags.length > 0 && (
            <span class="flex gap-2 flex-wrap">
              {entry.data.tags.map((tag: string) => (
                <a href={`/blog?tag=${encodeURIComponent(tag)}`}
                   class="px-3 py-1 rounded-lg bg-finance-blue/10 text-finance-blue border border-finance-blue/30 hover:bg-finance-purple/20 hover:border-finance-purple/50 transition-all text-xs font-medium">
                  {tag}
                </a>
              ))}
            </span>
          )}
        </div>
      )}

      <!-- Research: Non-clickable tags -->
      {isResearchEntry(entry) && entry.data.tags && entry.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-3 pt-2">
          {entry.data.tags.map((tag: string) => (
            <span class="px-3 py-1 rounded-lg bg-finance-cyan/10 text-finance-cyan border border-finance-cyan/30 text-sm font-medium">
              {tag}
            </span>
          ))}
        </div>
      )}

      <!-- Research: External links (DOI, arXiv, PDF) -->
      {isResearchEntry(entry) && (entry.data.doi || entry.data.arxiv || entry.data.pdfUrl) && (
        <div class="flex flex-wrap gap-3 pt-4 border-t border-glass-border">
          {entry.data.pdfUrl && (
            <a href={entry.data.pdfUrl} target="_blank" rel="noopener noreferrer"
               class="glass-btn text-finance-cyan hover:text-white inline-flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              Download PDF
            </a>
          )}
          {entry.data.doi && (
            <a href={`https://doi.org/${entry.data.doi}`} target="_blank" rel="noopener noreferrer"
               class="glass-btn text-neutral-300 hover:text-white">
              DOI: {entry.data.doi}
            </a>
          )}
          {entry.data.arxiv && (
            <a href={`https://arxiv.org/abs/${entry.data.arxiv}`} target="_blank" rel="noopener noreferrer"
               class="glass-btn text-neutral-300 hover:text-white">
              arXiv: {entry.data.arxiv}
            </a>
          )}
        </div>
      )}
    </div>
  </header>

  <!-- Two-column layout: TOC on left, Thesis + Content on right -->
  <div class="flex flex-col lg:flex-row gap-8">
    <!-- Table of Contents + Series List Sidebar (order-2 on mobile, order-1 on desktop) -->
    <aside class="order-2 lg:order-1 w-full lg:w-64 shrink-0 flex flex-col gap-4">
      <nav class="glass-card p-6 lg:sticky lg:top-8 lg:max-h-[calc(100vh-4rem)] lg:overflow-y-auto">
        <h2 class="text-xl font-semibold gradient-text mb-4">Table of Contents</h2>
        <div id="toc-container"></div>
      </nav>

      <!-- Series home: article list below TOC -->
      {seriesArticles && seriesArticles.length > 0 && isBlogEntry(entry) && !parentSeries && (
        <div class="glass-card p-6">
          <h2 class="text-base font-semibold gradient-text mb-4">Articles in this Series</h2>
          <ol class="flex flex-col gap-2">
            {seriesArticles.map((article) => (
              <li>
                <a
                  href={`/blog/${article.slug}`}
                  class="group flex items-start gap-3 py-2 px-2 rounded-lg hover:bg-finance-purple/5 transition-all"
                >
                  <span class="shrink-0 w-5 h-5 rounded-md bg-finance-purple/20 border border-finance-purple/30 text-finance-purple text-[10px] font-bold flex items-center justify-center mt-0.5">
                    {article.data.articleNumber}
                  </span>
                  <p class="text-sm text-neutral-400 group-hover:text-finance-cyan transition-colors leading-snug">
                    {article.data.title}
                  </p>
                </a>
              </li>
            ))}
          </ol>
        </div>
      )}
    </aside>

    <!-- Main Content Area: Thesis + Article (uses contents on mobile for flat ordering) -->
    <div class="contents lg:order-2 lg:flex lg:flex-col lg:gap-8 lg:flex-1 lg:min-w-0">
      {thesisHtml && (
        <div class="order-1 lg:order-0 glass-card p-6 md:p-8">
          <h2 class="text-xl font-semibold gradient-text mb-4">Thesis</h2>
          <div class="thesis-content text-neutral-300 leading-relaxed" set:html={thesisHtml} />
        </div>
      )}

      <!-- Sub-article: prev/next navigation (after thesis, before article) -->
      {isBlogEntry(entry) && parentSeries && (
        <div class="order-2 lg:order-0 grid grid-cols-2 gap-4">
          {prevArticle ? (
            <a
              href={`/blog/${prevArticle.slug}`}
              class="group glass-card p-5 flex flex-col gap-2 hover:border-finance-purple/40 transition-all"
            >
              <span class="text-xs text-neutral-500 uppercase tracking-wide flex items-center gap-1">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
                Part {prevArticle.data.articleNumber}
              </span>
              <p class="font-semibold text-white group-hover:text-finance-cyan transition-colors leading-snug text-sm">
                {prevArticle.data.title}
              </p>
            </a>
          ) : (
            <a
              href={`/blog/${parentSeries.slug}`}
              class="group glass-card p-5 flex flex-col gap-2 hover:border-finance-purple/40 transition-all"
            >
              <span class="text-xs text-neutral-500 uppercase tracking-wide flex items-center gap-1">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
                Series Overview
              </span>
              <p class="font-semibold text-white group-hover:text-finance-cyan transition-colors leading-snug text-sm">
                {parentSeries.data.title}
              </p>
            </a>
          )}
          {nextArticle ? (
            <a
              href={`/blog/${nextArticle.slug}`}
              class="group glass-card p-5 flex flex-col gap-2 items-end text-right hover:border-finance-purple/40 transition-all"
            >
              <span class="text-xs text-neutral-500 uppercase tracking-wide flex items-center gap-1">
                Part {nextArticle.data.articleNumber}
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
              </span>
              <p class="font-semibold text-white group-hover:text-finance-cyan transition-colors leading-snug text-sm">
                {nextArticle.data.title}
              </p>
            </a>
          ) : (
            <a
              href={`/blog/${parentSeries.slug}`}
              class="group glass-card p-5 flex flex-col gap-2 items-end text-right hover:border-finance-purple/40 transition-all"
            >
              <span class="text-xs text-neutral-500 uppercase tracking-wide flex items-center gap-1">
                Series Overview
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
              </span>
              <p class="font-semibold text-white group-hover:text-finance-cyan transition-colors leading-snug text-sm">
                {parentSeries.data.title}
              </p>
            </a>
          )}
        </div>
      )}

      <article class={`order-3 lg:order-0 content-article ${type} glass-card p-8 md:p-12`}>
        <div class="content-body">
          <Content />
        </div>
      </article>
    </div>
  </div>
</main>

<script>
  // Generate hierarchical TOC from headings
  const article = document.querySelector('.content-article');
  const tocContainer = document.getElementById('toc-container');
  if (article && tocContainer) {
    const headings = article.querySelectorAll('h2, h3');
    if (headings.length > 0) {
      const ol = document.createElement('ol');
      ol.className = 'space-y-2 text-sm';

      let currentH2Li = null;
      let currentH3Ol = null;

      headings.forEach((heading, index) => {
        const id = heading.id || `heading-${index}`;
        heading.id = id;

        if (heading.tagName === 'H2') {
          const li = document.createElement('li');
          const a = document.createElement('a');
          a.href = `#${id}`;
          a.textContent = heading.textContent;
          a.className = 'text-finance-cyan hover:text-white transition-colors font-medium block py-1';
          li.appendChild(a);
          ol.appendChild(li);
          currentH2Li = li;
          currentH3Ol = null;
        } else if (heading.tagName === 'H3' && currentH2Li) {
          if (!currentH3Ol) {
            currentH3Ol = document.createElement('ol');
            currentH3Ol.className = 'ml-0 mt-1 space-y-1';
            currentH2Li.appendChild(currentH3Ol);
          }
          const li = document.createElement('li');
          const a = document.createElement('a');
          a.href = `#${id}`;
          a.textContent = heading.textContent;
          a.className = 'text-neutral-400 hover:text-neutral-300 transition-colors block py-1 pl-4';
          li.appendChild(a);
          currentH3Ol.appendChild(li);
        }
      });

      tocContainer.appendChild(ol);
    }
  }
</script>
