---
type Props = {
  href: string;
  filename: string;
};

const { href, filename } = Astro.props;
---

<a
  href={href}
  download={filename}
  class="group not-prose flex items-stretch gap-3 px-3 py-2 my-4 rounded-lg border border-finance-cyan/25 bg-finance-cyan/5 hover:bg-finance-cyan/10 hover:border-finance-cyan/50 transition-all duration-200 no-underline"
>
  <div class="flex-shrink-0 aspect-square flex items-center justify-center w-8 rounded-md bg-finance-cyan/10 border border-finance-cyan/20">
    <svg class="w-5 h-5 text-finance-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
    </svg>
  </div>
  <div class="flex-1 min-w-0 flex flex-col justify-center gap-1.5">
    <span class="text-xs text-finance-cyan/50 font-medium uppercase tracking-wider leading-none">Download</span>
    <span class="text-finance-cyan font-medium text-sm leading-tight">{filename}</span>
  </div>
  <svg class="self-center w-4 h-4 text-finance-cyan/50 group-hover:text-finance-cyan group-hover:translate-y-0.5 transition-all duration-200 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
  </svg>
</a>
